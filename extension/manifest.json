{
  "manifest_version": 2,
  "name": "Copy Tab URLs",
  "short_name": "Copy URLs",
  "version": "1.1.0",
  "description": "Copy the URLs of all open tabs to the clipboard (Chrome, Firefox, LibreWolf).",
  "permissions": [
    "tabs",
    "clipboardWrite"
  ],
  "browser_action": {
    "default_title": "Copy Tab URLs",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "copy-tab-urls@ref.draeician.dev",
      "strict_min_version": "109.0"
    }
  }
}
